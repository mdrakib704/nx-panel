  "referralRewardCoins": 50,
  "enableAds": true,
  "enableCoins": true,
  "enableBackups": true,
  "backupRetentionDays": 30,
  "backupScheduleInterval": 86400000,
  "maintenanceMode": false,
  "databasePath": "./database/panel.db",
  "logsPath": "./logs",
  "uploadsPath": "./uploads",
  "backupsPath": "./backups",
  "serversPath": "./servers",
  "backgroundsPath": "./backgrounds",
  "maxFileUploadSize": 104857600,
  "allowedFileTypes": [
    ".jar",
    ".zip",
    ".yml",
    ".yaml",
    ".properties",
    ".json",
    ".txt"
  ],
  "allowedVideoFormats": [
    ".mp4",
    ".webm"
  ],
  "sessionTimeout": 86400000,
  "rateLimitWindowMs": 900000,
  "rateLimitMaxRequests": 100,
  "corsOrigins": [
    "http://localhost:3000"
